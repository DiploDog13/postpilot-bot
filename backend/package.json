{
  "name": "postpilot-backend",
  "version": "1.0.0",
  "description": "PostPilot Bot Backend",
  "main": "dist/main.js",
  "scripts": {
    "build": "node ./node_modules/typescript/bin/tsc",
    "start": "node dist/main.js",
    "dev": "node --loader ts-node/esm src/main.ts",
    "watch": "ts-node --watch src/main.ts",
    "postinstall": "chmod +x node_modules/.bin/*"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.14",
    "@grammyjs/conversations": "^1.2.0",
    "grammy": "^1.19.2",
    "hono": "^4.0.0",
    "openai": "^4.24.1",
    "pg": "^8.11.3",
    "jsonwebtoken": "^9.0.2",
    "node-fetch": "^3.3.2",
    "openai": "^4.77.0",
    "bcryptjs": "^2.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/pg": "^8.11.10",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/bcryptjs": "^2.4.6",
    "typescript": "^5.7.2",
    "ts-node": "^10.9.2"
  },
  "keywords": [
    "telegram",
